# ─────────────────────────────────────────────────────────────────────────────
# LinkedIn Smart Search Wrapper — Environment Variables
# Domain: deepakkulkarni.space
# Copy this file to .env and fill in all values before deploying.
# NEVER commit the .env file to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── App ────────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
ALLOWED_ORIGINS=https://deepakkulkarni.space,https://www.deepakkulkarni.space

# ── Session ───────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
SESSION_SECRET=REPLACE_WITH_64_CHAR_RANDOM_HEX

# Generate with: openssl rand -hex 32
# This key encrypts LinkedIn OAuth tokens stored in Redis sessions
SESSION_ENCRYPTION_KEY=REPLACE_WITH_32_CHAR_RANDOM_HEX

# ── LinkedIn OAuth 2.0 ────────────────────────────────────────────────────────
# Obtain from: https://developer.linkedin.com/apps
# Ensure your LinkedIn account has Premium tier
LINKEDIN_CLIENT_ID=YOUR_LINKEDIN_APP_CLIENT_ID
LINKEDIN_CLIENT_SECRET=YOUR_LINKEDIN_APP_CLIENT_SECRET
LINKEDIN_CALLBACK_URL=https://deepakkulkarni.space/auth/linkedin/callback

# ── Database (PostgreSQL 15) ──────────────────────────────────────────────────
POSTGRES_USER=lssw
# Generate with: openssl rand -hex 24
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_POSTGRES_PASSWORD
DATABASE_URL=postgresql://lssw:REPLACE_WITH_STRONG_POSTGRES_PASSWORD@db:5432/lssw?sslmode=disable

# ── Redis ──────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 24
REDIS_PASSWORD=REPLACE_WITH_STRONG_REDIS_PASSWORD
REDIS_URL=redis://:REPLACE_WITH_STRONG_REDIS_PASSWORD@redis:6379

# ── Playwright ────────────────────────────────────────────────────────────────
PLAYWRIGHT_MAX_PAGES=5
PLAYWRIGHT_BROWSER_TIMEOUT_MS=15000
# Random delay range to avoid bot detection (milliseconds)
PLAYWRIGHT_NAV_DELAY_MIN_MS=500
PLAYWRIGHT_NAV_DELAY_MAX_MS=1500

# ── Rate Limiting ─────────────────────────────────────────────────────────────
# Max searches per user per hour (LinkedIn bot-detection protection)
RATE_LIMIT_SEARCHES_PER_HOUR=30
RATE_LIMIT_WINDOW_SECONDS=3600

# ── Cache ──────────────────────────────────────────────────────────────────────
# Candidate result TTL in seconds (max 600 per GDPR data minimization)
RESULT_CACHE_TTL_SECONDS=600

# ── Container Registry (GitHub Container Registry) ────────────────────────────
GHCR_ORG=YOUR_GITHUB_ORG_OR_USERNAME
IMAGE_TAG=latest

# ── GitHub Actions Secrets (set these in GitHub repo Settings > Secrets) ──────
# HOSTINGER_HOST=YOUR_VPS_IP
# HOSTINGER_USER=deploy
# HOSTINGER_SSH_KEY=<contents of ~/.ssh/id_ed25519 private key>
# All the above variables should also be set as GitHub Secrets
