# ─── LinkedIn Smart Search Wrapper — Nginx Configuration ────────────────────
# Domain: deepakkulkarni.space
# Generated for production deployment on Hostinger Cloud VPS

# Rate limiting zones
limit_req_zone $binary_remote_addr zone=api:10m rate=100r/m;
limit_req_zone $binary_remote_addr zone=auth:10m rate=10r/m;
limit_conn_zone $binary_remote_addr zone=perip:10m;

# ─── HTTP → HTTPS redirect ────────────────────────────────────────────────────
server {
    listen 80;
    listen [::]:80;
    server_name deepakkulkarni.space www.deepakkulkarni.space;

    # ACME challenge for Certbot
    location /.well-known/acme-challenge/ {
        root /var/www/certbot;
        try_files $uri =404;
    }

    # All other HTTP → HTTPS
    location / {
        return 301 https://deepakkulkarni.space$request_uri;
    }
}

# ─── www → non-www redirect (HTTPS) ──────────────────────────────────────────
server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name www.deepakkulkarni.space;

    ssl_certificate     /etc/letsencrypt/live/deepakkulkarni.space/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/deepakkulkarni.space/privkey.pem;

    return 301 https://deepakkulkarni.space$request_uri;
}

# ─── Main HTTPS server ────────────────────────────────────────────────────────
server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name deepakkulkarni.space;

    # ── SSL/TLS ──
    ssl_certificate     /etc/letsencrypt/live/deepakkulkarni.space/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/deepakkulkarni.space/privkey.pem;
    ssl_session_timeout 1d;
    ssl_session_cache shared:SSL:50m;
    ssl_session_tickets off;
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384:ECDHE-ECDSA-CHACHA20-POLY1305:ECDHE-RSA-CHACHA20-POLY1305;
    ssl_prefer_server_ciphers off;
    ssl_stapling on;
    ssl_stapling_verify on;

    # ── Security Headers ──
    add_header Strict-Transport-Security "max-age=63072000; includeSubDomains; preload" always;
    add_header X-Frame-Options "DENY" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;
    add_header X-Data-Region "EU" always;
    add_header X-Privacy-Policy "https://deepakkulkarni.space/privacy" always;
    add_header Permissions-Policy "geolocation=(), microphone=(), camera=(), payment=(), usb=(), bluetooth=()" always;
    add_header Content-Security-Policy "
        default-src 'self';
        script-src 'self';
        style-src 'self' 'unsafe-inline';
        img-src 'self' data: https://media.licdn.com https://static.licdn.com;
        connect-src 'self';
        font-src 'self';
        object-src 'none';
        base-uri 'self';
        frame-ancestors 'none';
        form-action 'self';
    " always;

    # ── Connection limits ──
    limit_conn perip 20;

    # ── Logging ──
    access_log /var/log/nginx/access.log;
    error_log /var/log/nginx/error.log warn;

    # ── Health check (Nginx level — no rate limit) ──
    location = /health-nginx {
        return 200 'ok';
        add_header Content-Type text/plain;
    }

    # ── Backend health ──
    location = /health {
        proxy_pass http://app:3000;
        proxy_set_header Host $host;
        access_log off;
    }

    # ── LinkedIn OAuth callback ──
    location /auth/linkedin/callback {
        limit_req zone=auth burst=5 nodelay;
        proxy_pass http://app:3000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # ── Auth routes ──
    location /auth/ {
        limit_req zone=auth burst=10 nodelay;
        proxy_pass http://app:3000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 10s;
    }

    # ── API routes ──
    location /api/ {
        limit_req zone=api burst=20 nodelay;
        proxy_pass http://app:3000;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_cache_bypass $http_upgrade;
        proxy_read_timeout 30s;
        proxy_send_timeout 30s;
        # SSE support (for /api/search/stream/*)
        proxy_buffering off;
        proxy_cache off;
    }

    # ── Frontend static SPA ──
    location / {
        proxy_pass http://frontend:80;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 10s;
    }

    # ── Block common attack vectors ──
    location ~* \.(php|asp|aspx|jsp|cgi|pl|py)$ {
        return 404;
    }
    location ~ /\. {
        deny all;
    }
}
